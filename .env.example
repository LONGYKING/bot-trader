# Database
DATABASE_URL=postgresql+asyncpg://bottrader:bottrader@localhost:5432/bottrader

# Redis
REDIS_DSN=redis://localhost:6379/0

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-64-char-hex-string

# App
ENVIRONMENT=development
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]

# Sentry (optional)
SENTRY_DSN=

# Google Sheets (optional)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars!!
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRES_MINUTES=60
JWT_REFRESH_EXPIRES_DAYS=7

# ── Payment provider ─────────────────────────────────────────────────────────
# Switch providers with ONE env var: stripe | paddle | lemonsqueezy
PAYMENT_PROVIDER=stripe

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Paddle
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox

# Lemon Squeezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
